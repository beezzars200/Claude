<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>UMN Tickets — Admin</title>
  <link rel="stylesheet" href="/css/manage.css">
</head>
<body>
  <div class="app" id="app">
    <div class="sidebar-backdrop" id="sidebar-backdrop"></div>

    <!-- Mobile top bar -->
    <div class="mobile-topbar">
      <button class="mobile-menu-btn" id="mobile-menu-btn">
        <span></span><span></span><span></span>
      </button>
      <span class="mobile-title">UMN Tickets</span>
    </div>

    <aside class="sidebar" id="sidebar">
      <div class="sidebar-logo">
        <div class="sidebar-logo-mark">T</div>
        <div>
          <h1>UMN Tickets</h1>
          <p>Admin Console</p>
        </div>
        <button class="sidebar-close-btn" id="sidebar-close" title="Close menu">&#x2715;</button>
      </div>
      <nav class="sidebar-nav">
        <p class="nav-section">Main</p>
        <button class="nav-item active" data-view="dashboard">Dashboard</button>
        <button class="nav-item" data-view="organisations">Organisations</button>
        <button class="nav-item" data-view="events">Events</button>
        <p class="nav-section">Tickets</p>
        <button class="nav-item" data-view="import">Import CSV</button>
        <button class="nav-item" data-view="generate">Generate Tickets</button>
        <p class="nav-section">Access</p>
        <button class="nav-item" data-view="users">Admin Users</button>
      </nav>
      <div class="sidebar-bottom">
        <div class="sidebar-user">
          <span class="sidebar-username"><%=username%></span>
          <a href="/auth/logout" class="btn btn-sm">Logout</a>
        </div>
      </div>
    </aside>

    <main class="main-content">
      <button class="sidebar-expand-btn" id="sidebar-expand" title="Open menu">&#9776;</button>

      <!-- Dashboard -->
      <section id="view-dashboard" class="view active">
        <div class="view-header">
          <div><h2>Dashboard</h2><p class="view-sub">Overview of all events and activity</p></div>
          <div class="header-filters">
            <select id="dashboard-org-filter" class="filter-select">
              <option value="">All Organisations</option>
            </select>
          </div>
        </div>
        <div class="stats-row" id="dashboard-stats">
          <div class="stat-card"><span class="stat-number" id="stat-events">—</span><span class="stat-label">Events</span></div>
          <div class="stat-card"><span class="stat-number" id="stat-tickets">—</span><span class="stat-label">Total Tickets</span></div>
          <div class="stat-card"><span class="stat-number" id="stat-scanned">—</span><span class="stat-label">Scanned</span></div>
          <div class="stat-card"><span class="stat-number" id="stat-remaining">—</span><span class="stat-label">Remaining</span></div>
        </div>
        <div id="dashboard-events-list" class="card-list"></div>
      </section>

      <!-- Organisations -->
      <section id="view-organisations" class="view">
        <div class="view-header">
          <div><h2>Organisations</h2><p class="view-sub">Manage clubs and organisations</p></div>
          <button class="btn btn-primary" id="show-add-org">+ Add Organisation</button>
        </div>
        <div id="org-form-container" class="form-card hidden">
          <h3>New Organisation</h3>
          <div class="form-row">
            <div class="form-group"><label>Organisation Name</label><input type="text" id="org-name" placeholder="e.g. Grattan United FC"></div>
            <div class="form-group"><label>Slug</label><input type="text" id="org-slug" placeholder="auto-generated"></div>
          </div>
          <div class="form-row">
            <div class="form-group"><label>Primary Colour</label><input type="color" id="org-primary" value="#0f172a"></div>
            <div class="form-group"><label>Accent Colour</label><input type="color" id="org-accent" value="#6366f1"></div>
            <div class="form-group"><label>Text Colour</label><input type="color" id="org-secondary" value="#ffffff"></div>
          </div>
          <div class="form-group">
            <label>Logo</label>
            <div class="file-pick-row">
              <button class="btn btn-sm" id="pick-org-logo">Choose Image</button>
              <span id="org-logo-name" class="file-name">No file chosen</span>
            </div>
            <img id="org-logo-preview" class="logo-preview hidden" alt="">
            <input type="hidden" id="org-logo-data">
          </div>
          <div class="form-actions">
            <button class="btn btn-primary" id="save-org">Save Organisation</button>
            <button class="btn" id="cancel-org">Cancel</button>
          </div>
        </div>
        <div id="orgs-list" class="card-list"></div>
      </section>

      <!-- Events -->
      <section id="view-events" class="view">
        <div class="view-header">
          <div><h2>Events</h2><p class="view-sub">Create and manage events</p></div>
          <button class="btn btn-primary" id="show-add-event">+ Add Event</button>
        </div>
        <div id="event-form-container" class="form-card hidden">
          <h3>New Event</h3>
          <div class="form-row">
            <div class="form-group"><label>Organisation</label><select id="event-org"></select></div>
            <div class="form-group"><label>Event Name</label><input type="text" id="event-name" placeholder="e.g. Annual Club Gala 2025"></div>
          </div>
          <div class="form-row">
            <div class="form-group"><label>Date</label><input type="date" id="event-date"></div>
            <div class="form-group"><label>Time</label><input type="text" id="event-time" placeholder="e.g. 7:00 PM"></div>
            <div class="form-group"><label>Venue</label><input type="text" id="event-venue" placeholder="e.g. The Grand Ballroom"></div>
          </div>
          <div class="form-group"><label>Slug</label><input type="text" id="event-slug" placeholder="auto-generated"></div>
          <div class="form-row">
            <div class="form-group"><label>Primary Colour</label><input type="color" id="event-primary" value="#0f172a"></div>
            <div class="form-group"><label>Accent Colour</label><input type="color" id="event-accent" value="#6366f1"></div>
            <div class="form-group"><label>Text Colour</label><input type="color" id="event-secondary" value="#ffffff"></div>
          </div>
          <div class="form-group">
            <label>Logo</label>
            <div class="file-pick-row">
              <button class="btn btn-sm" id="pick-event-logo">Choose Image</button>
              <span id="event-logo-name" class="file-name">No file chosen</span>
            </div>
            <img id="event-logo-preview" class="logo-preview hidden" alt="">
            <input type="hidden" id="event-logo-data">
          </div>
          <div class="form-actions">
            <button class="btn btn-primary" id="save-event">Save Event</button>
            <button class="btn" id="cancel-event">Cancel</button>
          </div>
        </div>
        <div id="events-list" class="card-list"></div>
      </section>

      <!-- Import CSV -->
      <section id="view-import" class="view">
        <div class="view-header"><div><h2>Import Attendees</h2><p class="view-sub">Upload a CSV file to add attendees to an event</p></div></div>
        <div class="form-card">
          <div class="form-group"><label>Select Event</label><select id="import-event"></select></div>
          <div class="form-group">
            <label>CSV File</label>
            <p class="field-hint">Required columns: <code>Name</code>, <code>No of Tickets</code> — Optional: <code>Email</code>, <code>Phone</code>, <code>Company or Organisation</code></p>
            <div class="file-pick-row">
              <button class="btn btn-sm" id="pick-csv">Choose CSV File</button>
              <span id="csv-file-name" class="file-name">No file chosen</span>
            </div>
          </div>
          <div id="csv-preview" class="hidden">
            <div class="preview-header">
              <h4>Preview</h4>
              <div class="preview-badges">
                <span class="badge badge-blue"><span id="csv-count">0</span> attendees</span>
                <span class="badge badge-green"><span id="ticket-count">0</span> tickets</span>
              </div>
            </div>
            <div class="table-scroll">
              <table id="preview-table" class="data-table">
                <thead><tr><th>Name</th><th>Email</th><th>Phone</th><th>Company</th><th>Tickets</th></tr></thead>
                <tbody id="preview-tbody"></tbody>
              </table>
            </div>
          </div>
          <div class="form-actions">
            <button class="btn btn-primary" id="import-btn" disabled>Import to Database</button>
          </div>
          <div id="import-result" class="hidden"></div>
        </div>
      </section>

      <!-- Generate Tickets -->
      <section id="view-generate" class="view">
        <div class="view-header"><div><h2>Generate Tickets</h2><p class="view-sub">Create PDF tickets for an event</p></div></div>

        <!-- Shown in browser -->
        <div id="gen-web-notice" class="form-card hidden">
          <div class="desktop-notice">
            <div class="desktop-notice-icon">💻</div>
            <h3>Desktop App Required</h3>
            <p class="muted">PDF ticket generation requires the UMN Tickets desktop app for Mac.</p>
            <p class="muted" style="margin-top:6px">Everything else works here in the browser.</p>
          </div>
        </div>

        <!-- Shown in Electron -->
        <div id="gen-electron-section" class="form-card hidden">
          <div class="form-group"><label>Select Event</label><select id="gen-event"></select></div>
          <div id="gen-ticket-info" class="info-box hidden"></div>
          <div class="form-actions">
            <button class="btn btn-primary" id="gen-btn" disabled>Generate & Download PDF Tickets</button>
          </div>
          <div id="gen-result" class="hidden"></div>
        </div>
      </section>

      <!-- Admin Users -->
      <section id="view-users" class="view">
        <div class="view-header">
          <div><h2>Admin Users</h2><p class="view-sub">Create logins for door staff and org admins</p></div>
          <button class="btn btn-primary" id="show-add-user">+ Add User</button>
        </div>
        <div id="user-form-container" class="form-card hidden">
          <h3>New Admin User</h3>
          <p class="field-hint" style="margin-bottom:16px">Organisation admins only see their own events. Leave blank for super admin access.</p>
          <div class="form-row">
            <div class="form-group"><label>Username</label><input type="text" id="user-username" placeholder="e.g. grattan-admin"></div>
            <div class="form-group"><label>Password</label><input type="password" id="user-password" placeholder="Strong password"></div>
          </div>
          <div class="form-group"><label>Organisation (optional)</label><select id="user-org"><option value="">Super Admin — sees all events</option></select></div>
          <div class="form-actions">
            <button class="btn btn-primary" id="save-user">Create User</button>
            <button class="btn" id="cancel-user">Cancel</button>
          </div>
        </div>
        <div id="users-list" class="card-list"></div>
      </section>

    </main>
  </div>

  <div id="toast" class="toast hidden"></div>

  <!-- Hidden file inputs for web (Electron uses native dialogs instead) -->
  <input type="file" id="web-csv-input" accept=".csv" style="display:none">
  <input type="file" id="web-org-logo-input" accept="image/*" style="display:none">
  <input type="file" id="web-event-logo-input" accept="image/*" style="display:none">

  <script>const IS_ELECTRON = navigator.userAgent.includes('Electron');</script>
  <script src="/js/manage-api.js"></script>
  <script src="/js/manage-app.js"></script>
</body>
</html>
