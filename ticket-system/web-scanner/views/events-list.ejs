<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Events — UMN Tickets</title>
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body class="events-page">
  <header class="site-header">
    <div class="container">
      <h1>Events</h1>
      <p>Select an event to begin scanning tickets</p>
    </div>
  </header>
  <main class="container">
    <% if (!events.length) { %>
      <div class="empty-state">
        <p>No active events at the moment.</p>
      </div>
    <% } else { %>
      <div class="events-grid">
        <% events.forEach(event => { %>
          <a href="/events/<%= event.slug %>/scan" class="event-card">
            <div class="event-card-top" style="background: <%= event.accent_color %>"></div>
            <% if (event.logo_url) { %>
              <img src="<%= event.logo_url %>" alt="<%= event.org_name %>" class="event-logo">
            <% } %>
            <div class="event-card-body">
              <p class="event-org"><%= event.org_name %></p>
              <h2><%= event.name %></h2>
              <p class="event-meta">
                <%= new Date(event.event_date).toLocaleDateString('en-GB', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %>
                <% if (event.event_time) { %> &middot; <%= event.event_time %><% } %>
              </p>
              <% if (event.venue) { %><p class="event-venue"><%= event.venue %></p><% } %>
            </div>
            <div class="event-card-footer">
              <span class="scan-count"><%= event.scanned_tickets || 0 %> / <%= event.total_tickets || 0 %> scanned</span>
              <span class="scan-btn">Scan &rarr;</span>
            </div>
          </a>
        <% }) %>
      </div>
    <% } %>
  </main>
</body>
</html>
