<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin — UMN Tickets</title>
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body class="admin-page">
  <header class="admin-header">
    <h1>UMN Tickets</h1>
    <div class="admin-nav">
      <span style="opacity:0.7"><%=username%></span>
      <a href="/auth/logout" class="btn btn-sm">Logout</a>
    </div>
  </header>
  <main class="container" style="max-width:1100px">
    <div class="stats-row" style="margin-top:28px">
      <div class="stat-card">
        <span class="stat-number"><%= events.length %></span>
        <span class="stat-label">Events</span>
      </div>
      <div class="stat-card">
        <span class="stat-number"><%= events.reduce((s,e)=>s+(parseInt(e.total_tickets)||0),0) %></span>
        <span class="stat-label">Tickets</span>
      </div>
      <div class="stat-card">
        <span class="stat-number"><%= events.reduce((s,e)=>s+(parseInt(e.scanned_tickets)||0),0) %></span>
        <span class="stat-label">Scanned</span>
      </div>
    </div>
    <section>
      <h2 style="font-size:18px;font-weight:700;margin-bottom:16px">Events</h2>
      <% if (!events.length) { %>
        <p style="color:var(--muted)">No events yet.</p>
      <% } else { %>
        <table class="admin-table">
          <thead>
            <tr>
              <th>Event</th>
              <th>Organisation</th>
              <th>Date</th>
              <th>Tickets</th>
              <th>Scanned</th>
              <th>Scanner</th>
            </tr>
          </thead>
          <tbody>
            <% events.forEach(e => { %>
              <tr>
                <td><strong><%= e.name %></strong></td>
                <td><%= e.org_name %></td>
                <td><%= new Date(e.event_date).toLocaleDateString('en-GB') %></td>
                <td><%= e.total_tickets || 0 %></td>
                <td><%= e.scanned_tickets || 0 %></td>
                <td><a href="/events/<%= e.slug %>/scan" target="_blank">/events/<%= e.slug %></a></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </section>
  </main>
</body>
</html>
