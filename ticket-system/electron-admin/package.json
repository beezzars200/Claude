{
  "name": "umn-ticket-admin",
  "version": "1.0.0",
  "description": "Unity Media Network Ticket Admin",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac --x64",
    "build:arm": "electron-builder --mac --arm64"
  },
  "dependencies": {
    "archiver": "^6.0.1",
    "axios": "^1.6.5",
    "csv-parse": "^5.5.3",
    "pdfkit": "^0.14.0",
    "qrcode": "^1.5.3"
  },
  "devDependencies": {
    "electron": "^28.1.4",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.unitymedianetwork.tickets",
    "productName": "UMN Ticket Admin",
    "mac": {
      "category": "public.app-category.business",
      "target": [{ "target": "dmg", "arch": ["x64", "arm64"] }],
      "icon": "resources/icon.icns"
    },
    "dmg": {
      "title": "UMN Ticket Admin"
    },
    "files": ["main.js", "preload.js", "src/**/*"]
  }
}
